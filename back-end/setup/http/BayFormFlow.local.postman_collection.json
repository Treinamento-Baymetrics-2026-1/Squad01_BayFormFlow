    {
      "name": "11. Criar pesquisa (201, salva researchId)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "['adminToken', 'companyId', 'gestorEmployeeId', 'validador1EmployeeId'].forEach(function (key) {",
              "  if (!pm.collectionVariables.get(key)) {",
              "    throw new Error('Variável {{' + key + '}} está vazia — rode os requests 1, 5, 6 e 3 antes deste (nessa ordem de dependência, não precisa ser a ordem numérica).');",
              "  }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.research_id) { pm.collectionVariables.set('researchId', json.research_id); }",
              "pm.test('201 + research_id', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(json).to.have.property('research_id');",
              "});"
            ]
          }
        }
