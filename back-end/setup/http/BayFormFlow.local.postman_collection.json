    { "key": "adminEmail", "value": "admin@bayformflow.local" },
    { "key": "adminPassword", "value": "Admin@12345" },
    { "key": "adminToken", "value": "" },
    { "key": "validador1Email", "value": "validador1@bayformflow.local" },
    { "key": "validador1Password", "value": "Senha12345" },
